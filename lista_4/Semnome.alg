algoritmo "semnome"

// Autor : Nicolas
// Data : 13/04/2026
// aperte F9
var

   grau, f: real

inicio

      escreval  ("vamos cálcular CḞ para FḞ")
      escreval ("Digite o valor do grau celsius")
      leia (grau)

// já bora

   f<-(grau *9/5) + 32

   escreva ("O valor encontrado foi", f)
fimalgoritmo
